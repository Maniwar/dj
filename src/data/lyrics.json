      {
        "type": "line",
        "voice": "dieter",
        "text": "I am Euro-Trash, completely unashamed!"
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "Dancing on the table, I won't be tamed!"
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "Too cheap, too loud, making such a scene!"
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "I’m the messiest girl that you've ever seen!"
      },
      {
        "type": "section",
        "text": "POST-CHORUS"
