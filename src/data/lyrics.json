      {
        "type": "line",
        "voice": "dieter",
        "text": "Trashy! (Uh-oh!)"
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "Nasty! (Uh-oh!)"
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "Messy! (Uh-oh!)"
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "Let's go!"
      },
      {
        "type": "section",
        "text": "DROP"
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "(Heavy relentless four-on-the-floor beat)"
      },
      {
        "type": "section",
        "text": "VERSE 2"
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "Your mascara is running down your face."
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "It looks very expensive."
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "Throw your drink in the air."
      },
      {
        "type": "line",
        "voice": "dieter",
        "text": "Mmm. Sticky."
      },
      {
        "type": "section",
        "text": "CHORUS"
      },
      {
        "type": "line",
